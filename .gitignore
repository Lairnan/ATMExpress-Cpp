# ==========================================
# CMake Build Outputs & Artifacts
# ==========================================
# Ignore standard and custom out-of-source build directories
build/
Build/
build-*/
out/
bin/

# Individual CMake system artifacts (in case of accidental in-source builds)
CMakeFiles/
CMakeCache.txt
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
Testing/
_deps/
CMakeUserPresets.json

# ==========================================
# Compiled Binaries and Objects
# ==========================================
# Object files and libraries
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# Executables
*.exe
*.out
*.app

# Debug and symbol files
*.pdb
*.ilk
*.idb
*.dwo

# Precompiled headers
*.gch
*.pch

# ==========================================
# IDE and Tool Specifics
# ==========================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# CLion / JetBrains
.idea/
cmake-build-*/

# Visual Studio
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# Xcode
*.xcodeproj/
*.xcworkspace/

# Dependency Managers
vcpkg_installed/
.conan/

# ==========================================
# Operating System files
# ==========================================
.DS_Store
Thumbs.db
